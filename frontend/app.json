{
  "expo": {
    "name": "DementiaAI",
    "slug": "dementia-ai-predict",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dementiaai.predict"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.dementiaai.predict"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "9dd37ebb-7550-468e-bd66-b2e64f39bf46"
      }
    }
  }
}
